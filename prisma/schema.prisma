generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String           @default("")
  plan           String           @default("free")
  /// @deprecated distributedCredits + purchasedCredits に移行中
  credits             Int              @default(30)
  distributedCredits  Int              @default(30)
  purchasedCredits    Int              @default(0)
  role           String           @default("user")
  handle         String?          @unique
  displayName    String           @default("")
  avatarUrl      String?
  publicId       String?          @unique
  referralCode   String?  @unique
  referredBy     String?
  referralCount  Int      @default(0)
  stripeCustomerId    String?
  stripeSubscriptionId String?
  currentPeriodEnd    DateTime?
  planExpiresAt       DateTime?
  subscriptionPlatform String?
  onboardingCompleted Boolean          @default(false)
  interests          String[]         @default([])
  monthlyRunsUsed    Int              @default(0)
  monthlyRunsResetAt DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  agents         UserAgent[]
  logs           AgentLog[]
  UserConnection UserConnection[]
  linkCodes      LinkCode[]
  deviceTokens   DeviceToken[]
  taskCompletions TaskCompletion[]
  creditTransactions CreditTransaction[]
  nodes          Node[]
  appLayout      UserAppLayout?
}

model UserAppLayout {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apps       Json     // Array of { id: string, position: number }
  hiddenApps Json     // Array of app ids user removed
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model AppOverride {
  id        String   @id @default(cuid())
  appId     String   @unique
  iconName  String?
  color1    String?
  color2    String?
  name      String?
  updatedAt DateTime @updatedAt
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  credits   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
 
  @@index([userId, taskId, createdAt])
}


model UserAgent {
  id           String     @id @default(cuid())
  userId       String
  name         String
  description  String     @default("")
  prompt       String
  trigger      String
  triggerCron  String     @default("")
  connections  String     @default("[]")
  active       Boolean    @default(true)
  outputType   String     @default("app")
  outputConfig String     @default("{}")
  useWebSearch Boolean    @default(false)
  runCount     Int        @default(0)
  isPublic        Boolean    @default(false)
  publicUseCount  Int        @default(0)
  originalAuthorId String?
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  logs         AgentLog[]
}

model AgentLog {
  id        String    @id @default(cuid())
  agentId   String
  userId    String
  status    String
  output    String    @default("")
  error     String    @default("")
  createdAt DateTime  @default(now())
  agent     UserAgent @relation(fields: [agentId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model RevenueCatEventProcessed {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())

  @@index([eventType, processedAt])
}

model RevenueRecord {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Int      // JPY
  userId          String?
  platform        String   // 'ios' | 'web'
  productId       String
  transactionType String   // 'subscription_new' | 'subscription_renewal' | 'subscription_cancel' | 'one_time'
  externalId      String?  // Stripe sub/invoice ID or RevenueCat transaction ID
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([userId, date])
  @@index([platform, date])
}

model ClaudeUsageLog {
  id                String   @id @default(cuid())
  userId            String?
  route             String
  model             String
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cacheReadTokens   Int      @default(0)
  cacheWriteTokens  Int      @default(0)
  webSearches       Int      @default(0)
  costJpyEstimate   Float    @default(0)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([route, createdAt])
  @@index([createdAt])
}

model AgentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  trigger     String
  triggerCron String   @default("")
  connections String   @default("[]")
  category    String   @default("general")
  variables   String   @default("[]")
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
}

model UserConnection {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String    @default("")
  scope        String    @default("")
  metadata     String    @default("{}")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])
}

model LinkCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("web")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CreditTransaction {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  type       String
  category   String
  creditKind String
  balance    Int
  relatedId  String?
  note       String   @default("")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Node {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String        @default("")
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  messages    NodeMessage[]
  memories    NodeMemory[]
  diaries     NodeDiary[]
  exchanges             NodeExchange[]
  openingVoice          String?   @db.Text
  openingVoiceCreatedAt DateTime?

  @@index([userId])
}

model NodeMessage {
  id        String   @id @default(cuid())
  nodeId    String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
}

model NodeMemory {
  id         String   @id @default(cuid())
  nodeId     String
  content    String   @db.Text
  importance Int      @default(5)
  createdAt  DateTime @default(now())
  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
}

model NodeDiary {
  id        String   @id @default(cuid())
  nodeId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
}

model NodeExchange {
  id           String   @id @default(cuid())
  nodeId       String
  userMessage  String   @db.Text
  nodeResponse String   @db.Text
  createdAt    DateTime @default(now())
  node         Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, createdAt])
}
