generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id              String   @id @default(cuid())
  name            String
  description     String
  category        String
  prompt          String   @default("")
  agentType       String   @default("prompt")
  webhookUrl      String   @default("")
  fields          String   @default("[]")
  authorName      String   @default("anonymous")
  authorId        String   @default("")
  stripeAccountId String   @default("")
  price           Float    @default(0)
  useCount        Int      @default(0)
  createdAt       DateTime @default(now())
}

model Purchase {
  id        String   @id @default(cuid())
  agentId   String
  userId    String
  createdAt DateTime @default(now())
}

model Subscription {
  id           String    @id @default(cuid())
  userId       String
  userEmail    String
  agentId      String
  frequency    String
  inputValues  String
  active       Boolean   @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime
  createdAt    DateTime  @default(now())
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  source      String
  lang        String   @default("en")
  description String   @default("")
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

model WorkSpace {
  id            String   @id @default(cuid())
  userId        String   @unique
  jobType       String   @default("")
  monthlyTarget Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkLog {
  id        String   @id @default(cuid())
  userId    String
  content   String
  income    Int      @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}